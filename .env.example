# ===========================================
# MCP BIKE FINDER - Variables de Entorno
# ===========================================

# Servidor MCP
MCP_SERVER_NAME=mcp-bike-finder
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=stdio

# Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bike_finder
DB_USER=postgres
DB_PASSWORD=tu_password_seguro
DB_SSLMODE=disable

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
S3_BUCKET_NAME=tu-bucket-de-bicis

# AWS Textract (OCR)
TEXTRACT_ENABLED=true

# Google Vision (Alternativa a Textract)
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_ENABLED=false

# Scraping
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; BikeFinderBot/1.0)
SCRAPER_DELAY_MS=1000
SCRAPER_MAX_RETRIES=3

# Marketplaces
MARKETPLACE_URLS=https://mercadolibre.com,https://olx.com,https://facebook.com/marketplace

# Logs
LOG_LEVEL=info
LOG_FORMAT=json